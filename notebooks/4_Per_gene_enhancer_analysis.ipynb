   "id": "a2228998-98d2-4a7b-8f34-8b2999cf718d",
   "metadata": {},
   "source": [
    "### 2 - Enhancer per gene - for PS-associated genes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7ffa8367-2e47-40d4-8b09-727ebcd26063",
   "metadata": {},
   "outputs": [],
   "source": [
    "def pick_enhancers_of_gene_set(gene_set, enh_df, category=None, category_label=None):\n",
    "    \"\"\"\n",
    "    For each gene it checks whether it has any enhancer in certain category and if yes it count total\n",
    "    number of enhancers, enhancers within the category and the rest. Output -  a dataframe with all counts.\n",
    "    \"\"\"\n",
    "    if category is None:\n",
    "        raise ValueError(\"Please provide target categories from enhancer dataset\")\n",
    "    \n",
    "    if category_label is None:\n",
    "        category_label = 'cat'\n",
    "\n",
    "    \n",
    "    total_n_enhs = {}\n",
    "    no_cat_n_enhs = {}\n",
    "    cat_n_enhs = {}\n",
    "\n",
    "    mask_cat = (enh_df['category'] == category)\n",
    "    gene_col = enh_df[\"gene\"].astype(str)\n",
    "\n",
    "    for g in gene_set:\n",
    "        g_esc = re.escape(g)\n",
    "        pattern = rf'(^|,\\s*){g_esc}(\\s*,|$)'\n",
    "\n",
    "        mask_total = gene_col.str.contains(pattern, regex=True, na=False)\n",
    "        mask_cat_gene = mask_total & mask_cat\n",
    "\n",
    "        tot = int(mask_total.sum())\n",
    "        cat = int(mask_cat_gene.sum())\n",
    "\n",
    "        total_n_enhs[g] = tot\n",
    "        no_cat_n_enhs[g] = tot - cat\n",
    "        cat_n_enhs[g] = cat\n",
    "\n",
    "    plot_df = (\n",
    "        pd.DataFrame({\n",
    "            \"total\": pd.Series(total_n_enhs),\n",
    "            f'no_{category_label}': pd.Series(no_cat_n_enhs),\n",
    "            category_label: pd.Series(cat_n_enhs),\n",
    "        })\n",
    "        .sort_values(\"total\", ascending=False)\n",
    "    )\n",
    "\n",
    "    return plot_df"
   ]
  },
