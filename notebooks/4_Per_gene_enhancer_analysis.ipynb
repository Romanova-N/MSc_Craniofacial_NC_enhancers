   "source": [
    "# number of enhancers per gene\n",
    "enh_count_dict = {k: v for k,v in sorted(enh_count_dict.items(), key=lambda item: item[1], reverse=True)}\n",
    "enh_count_dict.head(5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "4515e009",
   "metadata": {},
   "outputs": [],
   "source": [
    "#matrix presence-absence (TRUE-FALSE)\n",
    "counts = pd.Series(enh_count_dict, name=\"n_enhancers\")\n",
    "Kmax = int(counts.max()) if len(counts) else 0\n",
    "\n",
    "pr_matrix = pd.get_dummies(counts).reindex(columns=range(1, Kmax + 1), fill_value=0)\n",
    "pr_matrix.index.name = \"gene\"\n",
    "pr_matrix.columns.name = \"n_enhancers\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5cf72540-31b7-4a1f-841e-28823ab86036",
   "metadata": {},
   "outputs": [],
   "source": [
    "# list of genes associated with primate-specific+human_specific enhancers (for bar plots)\n",
    "genes = set()\n",
    "target_genes = adata.var.loc[adata.var['category'].isin(['primate_specific', 'human_unique']), 'gene'].to_list()\n",
    "\n",
    "for gen in target_genes:\n",
    "    for g in str(gen).split(\",\"):\n",
    "        g = g.strip()\n",
    "        if g:\n",
    "            genes.add(g)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "e09b550a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 0) Make sure columns are integers and sorted\n",
    "pr_matrix = pr_matrix.copy()\n",
    "pr_matrix.columns = pr_matrix.columns.astype(int)\n",
    "pr_matrix = pr_matrix.reindex(sorted(pr_matrix.columns), axis=1)\n",
    "\n",
    "# 1) Keep only targets present in the matrix\n",
    "targets = [g for g in genes if g in pr_matrix.index]\n",
    "\n",
    "# 2) Total genes per k\n",
    "total_per_k = pr_matrix.sum(axis=0).astype(int)\n",
    "\n",
    "# 3) Target genes per k (only for existing targets)\n",
    "target_per_k = (\n",
    "    pr_matrix.loc[targets].sum(axis=0).astype(int)\n",
    "    if len(targets) > 0 else pd.Series(0, index=total_per_k.index)\n",
    ")\n",
    "target_per_k = target_per_k.reindex(total_per_k.index, fill_value=0)\n",
    "\n",
    "# 4) Other genes per k\n",
    "other_per_k = (total_per_k - target_per_k).astype(int)\n",
    "\n",
    "# 5) Weighted mean number of enhancers per gene: E[k]\n",
    "x = total_per_k.index.to_numpy()          # k\n",
    "y = total_per_k.to_numpy()               # #genes with k\n",
    "mean_k = (x * y).sum() / y.sum() if y.sum() > 0 else np.nan\n",
    "\n",
    "# For plotting stacks + labels\n",
    "y_other = other_per_k.to_numpy()\n",
    "y_target = target_per_k.to_numpy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "da417fa4",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x800 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Global bar plot for all genes\n",
    "fig, ax = plt.subplots(figsize=(6, 4), dpi=200)\n",
    "\n",
    "ax.bar(x, y_other, label=\"Other genes\", color='#FEE391') \n",
    "ax.bar(x, y_target, bottom=y_other, label=\"Target genes\", color='#993404') # primate-specific+human_specific\n",
    "\n",
    "ax.set_title(\"Genes stratified by number of associated active enhancers\")\n",
    "ax.set_xlabel(\"Number of enhancers per gene\")\n",
    "ax.set_ylabel(\"Number of genes\")\n",
    "ax.legend()\n",
    "\n",
    "# nicer x ticks\n",
    "step = max(1, len(x)//10 + 1)\n",
    "ax.set_xticks(x[::step])\n",
    "\n",
    "# Mean line (average #enhancers per gene)\n",
    "if np.isfinite(mean_k):\n",
    "    ax.axvline(mean_k, linestyle=\"--\", linewidth=0.9, alpha=0.7, color='#707786')\n",
