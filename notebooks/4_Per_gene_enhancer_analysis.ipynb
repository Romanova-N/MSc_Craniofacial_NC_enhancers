    "            ha=\"left\", va=\"top\", fontsize=9)\n",
    "\n",
    "# Number of target genes per each bar\n",
    "texts = []\n",
    "for xi, total_yi, ti in zip(x, y, y_target):\n",
    "    if ti > 0:\n",
    "        texts.append(ax.text(xi, total_yi, str(int(ti)),\n",
    "                             ha=\"center\", va=\"bottom\", fontsize=9))\n",
    "adjust_text(\n",
    "    texts,\n",
    "    ax=ax,\n",
    "    only_move={\"text\": \"y+\"},\n",
    "    expand_text=(1.2, 1.2),\n",
    "    expand_points=(1.2, 1.2),\n",
    "    arrowprops=dict(arrowstyle=\"-\", color=\"grey\", lw=0.8),\n",
    ")\n",
    "\n",
    "fig.tight_layout()\n",
    "plt.savefig('../plots/Genes_stratified_by_N_enh.png', dpi=300, bbox_inches=\"tight\")\n",
    "plt.show()"
   ]
