    "# transparent background\n",
    "fig.patch.set_alpha(0)\n",
    "ax.set_facecolor(\"none\")\n",
    "\n",
    "# bars\n",
    "ax.barh(genes_top, other, color=\"#FEE391\", label=\"Other enhancers\", edgecolor=\"none\")\n",
    "ax.barh(genes_top, primate, left=other, color=\"#993404\", label=\"Primate-specific enhancers\", edgecolor=\"none\")\n",
    "\n",
    "# labels\n",
    "ax.set_xlabel(\"Number of enhancers\")\n",
    "ax.set_ylabel(\"\")\n",
    "# ax.set_title(\"Top genes by fraction of primate-specific enhancers\", fontweight=700)\n",
    "\n",
    "for y, (o, p, t, f) in enumerate(zip(other, primate, total, df_top[\"frac_primate\"].values)):\n",
    "    ax.text(o + p + 0.2, y, f\"{f*100:.0f} %\", va=\"center\", ha=\"left\")\n",
    "\n",
    "# legend\n",
    "leg = ax.legend(\n",
