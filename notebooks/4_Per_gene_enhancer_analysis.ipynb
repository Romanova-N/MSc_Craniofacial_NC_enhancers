   "source": [
    "### 1. Enhancer per gene - across all observations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2d000d15",
   "metadata": {},
   "outputs": [],
   "source": [
    "# for each gene in the dataset we define a set of associated enhancers\n",
    "genes_enhs_dict = defaultdict(set)\n",
    "\n",
    "for enh_id, row in adata.var.iterrows():\n",
    "    gene = row.get('gene', None)\n",
    "    if pd.isna(gene):\n",
    "        continue\n",
    "    for g in {x.strip() for x in str(gene).split(\",\")}:\n",
    "        if g:\n",
    "            genes_enhs_dict[g].add(enh_id)\n"
    "enh_count_dict = {gene: len(enhs) for gene, enhs in genes_enhs_dict.items()}\n"
   ]
  },
